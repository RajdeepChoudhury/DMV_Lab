    "import matplotlib.pyplot as plt\n",
    "x = [1,2,3,4,5]\n",
    "y = [10,20,15,25,30]\n",
    "plt.plot(x,y,marker = 'o')\n",
    "plt.xlabel('X values (Independent Variable):')\n",
    "plt.ylabel('Y values (Dependent Variable):')\n",
    "plt.title('X-Y Axis Data Plot')\n",
    "plt.grid(False)\n",
    "plt.show()"
   ]
